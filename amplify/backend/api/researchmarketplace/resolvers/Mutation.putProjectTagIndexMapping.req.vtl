{
  "version": "2018-05-29",
  "operation": "PutItem",
  "key": {
    "PK": $util.dynamodb.toDynamoDBJson($ctx.args.input.PK),
    "SK": $util.dynamodb.toDynamoDBJson($ctx.args.input.SK)
  },
  "attributeValues": $util.dynamodb.toMapValuesJson({
    "projectId": $ctx.args.input.projectId,
    "tagId": $ctx.args.input.tagId,
    "tagType": $ctx.args.input.tagType,
    "createdAt": $util.defaultIfNull($ctx.args.input.createdAt, $util.time.nowISO8601())
  })
}
