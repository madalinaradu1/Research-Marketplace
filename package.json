{
  "name": "uraf-website",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@aws-amplify/ui-react": "^5.0.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.913.0",
    "aws-amplify": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.14.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy:dev": "git add . && git commit -m 'Deploy to dev' && git push origin dev",
    "deploy:master": "git add . && git commit -m 'Deploy to master' && git push origin master",
    "seed:tags": "node --experimental-modules scripts/seed-tags.js",
    "seed:tags:additional": "node --experimental-modules scripts/seed-additional-tags.js",
    "test:tags": "node --experimental-modules scripts/test-tags.js",
    "seed:tags:test": "node --experimental-modules scripts/seed-tags-test.js",
    "test:recommendations": "node scripts/test-recommendation-scoring.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.993.0",
    "@aws-sdk/lib-dynamodb": "^3.993.0"
  }
}
